<%- include('partials/head', { pageTitle: 'Edit Book' }) %>
<%- include('partials/header', { activeNav: 'home', pageClass: 'form-page' }) %>

<h1 class="page-title">Update Book</h1>
<p class="page-subtitle">Edit details for <em><%= book.title %></em></p>

<div class="form-card">
  <form action="/edit/<%= book.id %>" method="POST">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" value="<%= book.title %>" required />
    </div>

    <div class="form-group">
      <label for="author">Author</label>
      <input type="text" id="author" name="author" value="<%= book.author %>" />
    </div>

    <div class="form-group">
      <label for="isbn">ISBN</label>
      <input type="text" id="isbn" name="isbn" value="<%= book.isbn %>" />
      <div class="cover-preview">
        <img
          src="https://covers.openlibrary.org/b/isbn/<%= book.isbn %>-M.jpg"
          alt="Book cover preview"
          onerror="this.style.display='none'"
        />
      </div>
    </div>

    <div class="form-group">
      <label for="summary">Summary</label>
      <textarea id="summary" name="summary"><%= book.summary %></textarea>
    </div>

    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes"><%= book.notes %></textarea>
    </div>

    <div class="form-group">
      <label for="rating">Rating (1–5)</label>
      <input type="number" id="rating" name="rating" min="1" max="5" value="<%= book.rating %>" />
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update Book</button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
