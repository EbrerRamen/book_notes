<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Add Book</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <h1>Add a New Book</h1>

  <!-- Form sends data to backend POST /add -->
  <form action="/add" method="POST">

    <!-- Book Title -->
    <label>Title</label>
    <input 
      type="text" 
      name="title" 
      placeholder="Enter book title" 
      required 
    />

    <!-- Author -->
    <label>Author</label>
    <input 
      type="text" 
      name="author" 
      placeholder="Enter author name" 
    />

    <!-- ISBN -->
    <label>ISBN</label>
    <input 
      type="text" 
      name="isbn" 
      placeholder="e.g. 9780385533225" 
    />

    <!-- Notes -->
    <label>Notes</label>
    <textarea 
      name="notes" 
      placeholder="Your thoughts about the book..."
    ></textarea>

    <!-- Rating -->
    <label>Rating (1–5)</label>
    <input 
      type="number" 
      name="rating" 
      min="1" 
      max="5"
    />

    <!-- Submit -->
    <button type="submit">Add Book</button>

  </form>

  <br />
  <a href="/">← Back to Home</a>

</body>
</html>